            <div id="albums-list" class="mt-4 grid gap-3"></div>
          </div>
        </div>
      </section>
    </main>
    </section>

    <dialog id="media-picker-dialog" class="admin-media-picker">
      <div class="admin-media-picker-panel">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <h3 class="text-xl font-black">选择媒体资源</h3>
            <p id="media-picker-hint" class="text-sm text-base-content/50">从媒体库选择已上传文件。</p>
          </div>
          <button id="close-media-picker" class="btn btn-sm rounded-xl" type="button">关闭</button>
        </div>
        <div class="mt-4 grid gap-3 md:grid-cols-[1fr_10rem]">
          <input id="media-picker-search" class="input input-bordered rounded-xl" type="search" placeholder="搜索文件名、路径、类型..." />
          <select id="media-picker-type" class="select select-bordered rounded-xl">
            <option value="">全部类型</option>
            <option value="image">图片</option>
            <option value="audio">音频</option>
            <option value="video">视频</option>
          </select>
        </div>
        <div id="media-picker-grid" class="admin-media-picker-grid mt-4"></div>
      </div>
    </dialog>

    <script>
      import '../scripts/admin-core.js';
      import '../scripts/admin-extra.js';
    </script>
  </body>
</html>
