---
import '../styles/global.scss'

const apiBase = import.meta.env.PUBLIC_API_BASE || '/api'
---

<!doctype html>
<html lang="zh-CN" data-theme="boke-green" data-theme-type="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="博客后台管理系统" />
    <title>后台管理 - 个人博客</title>
    <script is:inline>
      const themeTypes = { 'boke-night': 'dark', 'boke-punk': 'dark', 'boke-green': 'light' };
      const storedTheme = localStorage.getItem('theme') || 'boke-green';
      document.documentElement.setAttribute('data-theme', storedTheme);
      document.documentElement.setAttribute('data-theme-type', themeTypes[storedTheme] || 'light');
    </script>
  </head>
  <body class="admin-body min-h-screen text-base-content">
    <div class="site-bg-grid"></div>
    <section class="admin-shell" data-api-base={apiBase}>
    <aside class="admin-sidebar">
      <div>
        <p class="text-xs font-black uppercase text-primary">Control Panel</p>
        <h1 class="mt-2 text-3xl font-black leading-tight">后台管理</h1>
        <p class="mt-2 text-sm text-base-content/55">由 Express API 与 SQLite 提供数据能力。</p>
      </div>
      <nav class="mt-8 grid gap-2">
        <button class="admin-nav is-active" data-panel="dashboard">概览</button>
        <button class="admin-nav" data-panel="articles">内容中心</button>
        <button class="admin-nav" data-panel="media">媒体库</button>
        <button class="admin-nav" data-panel="fonts">字体库</button>
        <button class="admin-nav" data-panel="appearance">主题外观</button>
        <button class="admin-nav" data-panel="backup">备份导出</button>
        <button class="admin-nav" data-panel="settings">设置</button>
      </nav>
      <div class="mt-auto rounded-2xl bg-base-100/65 p-4 text-sm text-base-content/60">
        <p class="font-bold text-base-content">接口地址</p>
        <code id="api-base-label" class="mt-2 block break-all text-xs"></code>
      </div>
    </aside>

    <main class="admin-main">
      <div class="admin-topbar">
        <div>
          <p class="text-sm text-base-content/50">当前状态</p>
          <h2 id="admin-status" class="text-xl font-black">正在连接后端...</h2>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <a class="ryu-btn-ghost btn-sm" href="/">返回前台</a>
          <button id="refresh-admin" class="ryu-btn btn-sm">刷新数据</button>
          <button id="logout-admin" class="ryu-btn btn-sm hidden">退出登录</button>
        </div>
      </div>
      <p id="admin-notice" class="admin-notice" role="status" aria-live="polite"></p>

      <section id="login-panel" class="admin-panel">
        <div class="mx-auto max-w-md">
          <div class="ryu-card p-6">
            <h2 class="text-2xl font-black">登录后台</h2>
            <p class="mt-2 text-sm text-base-content/55">默认种子账号为 admin / admin123，可在后端种子数据中修改。</p>
            <form id="login-form" class="mt-6 grid gap-4">
              <label class="form-control">
                <span class="label-text">用户名</span>
                <input class="input input-bordered rounded-xl" name="username" autocomplete="username" placeholder="admin" required />
              </label>
              <label class="form-control">
                <span class="label-text">密码</span>
                <input class="input input-bordered rounded-xl" name="password" type="password" autocomplete="current-password" placeholder="请输入密码" required />
              </label>
              <button class="ryu-btn-primary" type="submit">登录并连接 API</button>
              <p id="login-message" class="min-h-6 text-sm text-error"></p>
            </form>
          </div>
        </div>
      </section>

      <section id="dashboard-panel" class="admin-panel hidden">
        <div class="admin-stats-grid">
          {[
            ['已发布', 'totalPosts'],
            ['草稿', 'draftPosts'],
            ['评论', 'totalComments'],
            ['阅读', 'totalViews'],
            ['分类', 'totalCategories'],
            ['媒体', 'totalMedia'],
            ['媒体回收站', 'trashedMedia'],
          ].map(([label, key]) => (
            <article class="ryu-card p-5">
              <p class="text-sm text-base-content/50">{label}</p>
              <strong class="mt-2 block text-3xl" data-stat={key}>-</strong>
            </article>
          ))}
        </div>
        <div class="mt-4 grid gap-4 lg:grid-cols-2">
          <div class="ryu-card p-5">
            <h3 class="font-black">最近发布</h3>
            <div id="recent-posts" class="mt-4 grid gap-3 text-sm"></div>
          </div>
          <div class="ryu-card p-5">
            <h3 class="font-black">系统提示</h3>
            <div id="admin-alerts" class="mt-4 grid gap-3 text-sm"></div>
          </div>
        </div>
        <div class="admin-dashboard-grid mt-4">
          <div class="ryu-card p-5">
            <div class="flex items-center justify-between gap-3">
              <h3 class="font-black">访问趋势</h3>
              <span class="text-xs text-base-content/45">近 30 天</span>
            </div>
            <div id="visit-chart" class="admin-bar-chart mt-4"></div>
          </div>
          <div class="ryu-card p-5">
            <div class="flex items-center justify-between gap-3">
              <h3 class="font-black">发布趋势</h3>
              <span class="text-xs text-base-content/45">近 30 天</span>
            </div>
            <div id="publish-chart" class="admin-bar-chart mt-4"></div>
          </div>
          <div class="ryu-card p-5">
            <h3 class="font-black">分类分布</h3>
            <div id="category-chart" class="admin-rank-chart mt-4"></div>
          </div>
          <div class="ryu-card p-5">
            <h3 class="font-black">热门文章</h3>
            <div id="popular-posts" class="mt-4 grid gap-3 text-sm"></div>
          </div>
        </div>
      </section>

      <section id="articles-panel" class="admin-panel hidden">
        <div class="ryu-card p-5">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <h2 class="text-2xl font-black">文章管理</h2>
              <p class="text-sm text-base-content/50">读取与写入后端 SQLite 文章表。</p>
            </div>
            <div class="flex flex-wrap gap-2">
              <select id="status-filter" class="select select-bordered select-sm rounded-xl">
                <option value="">全部状态</option>
                <option value="published">已发布</option>
                <option value="draft">草稿</option>
              </select>
              <label class="label cursor-pointer justify-start gap-2 rounded-xl bg-base-100/60 px-3 py-1">
                <input id="trash-filter" class="checkbox checkbox-sm" type="checkbox" />
                回收站
              </label>
              <button id="batch-delete" class="ryu-btn btn-sm">批量删除</button>
              <a id="new-article" class="ryu-btn-primary btn-sm" href="/admin/write">新建文章</a>
            </div>
          </div>
          <div class="mt-5 overflow-x-auto">
            <table class="table">
              <thead>
                <tr>
                  <th><input id="select-all-articles" class="checkbox checkbox-sm" type="checkbox" /></th>
                  <th>标题</th>
                  <th>状态</th>
                  <th>分类</th>
                  <th>阅读</th>
                  <th>更新时间</th>
                  <th class="text-right">操作</th>
                </tr>
              </thead>
              <tbody id="articles-table"></tbody>
            </table>
          </div>
        </div>
      </section>

      <section id="editor-panel" class="admin-panel hidden">
        <form id="article-form" class="ryu-card grid gap-5 p-5">
          <input type="hidden" name="id" />
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <h2 id="editor-title" class="text-2xl font-black">新建文章</h2>
              <p class="text-sm text-base-content/50">Markdown 内容会由后端渲染为 HTML 并写入数据库。</p>
            </div>
            <div class="flex gap-2">
              <button class="ryu-btn btn-sm" type="button" id="reset-editor">清空</button>
              <button class="ryu-btn-primary btn-sm" type="submit">保存文章</button>
            </div>
          </div>
          <label class="form-control">
            <span class="label-text">标题</span>
            <input class="input input-bordered rounded-xl" name="title" required />
          </label>
          <div class="grid gap-4 lg:grid-cols-3">
            <label class="form-control">
              <span class="label-text">状态</span>
              <select class="select select-bordered rounded-xl" name="status">
                <option value="draft">草稿</option>
                <option value="published">发布</option>
              </select>
            </label>
            <label class="form-control">
              <span class="label-text">可见性</span>
              <select class="select select-bordered rounded-xl" name="visibility">
                <option value="public">公开</option>
                <option value="private">私密</option>
              </select>
            </label>
            <label class="form-control">
              <span class="label-text">分类</span>
              <select id="category-select" class="select select-bordered rounded-xl" name="category_id">
                <option value="">无分类</option>
              </select>
            </label>
          </div>
          <label class="form-control">
            <span class="label-text">标签</span>
            <select id="tag-select" class="select select-bordered min-h-28 rounded-xl" name="tag_ids" multiple></select>
          </label>
          <div class="ryu-card grid gap-4 p-4">
            <div>
              <h3 class="text-lg font-black">文章字体</h3>
              <p class="text-sm text-base-content/50">从独立字体库选择标题和正文；字体导入请到侧边栏「字体库」。</p>
            </div>
            <div class="grid gap-3 lg:grid-cols-2">
              <label class="form-control">
                <span class="label-text">标题字体</span>
                <select id="title-font-select" class="select select-bordered rounded-xl" name="title_font_key"></select>
              </label>
              <label class="form-control">
                <span class="label-text">正文字体</span>
                <select id="body-font-select" class="select select-bordered rounded-xl" name="body_font_key"></select>
              </label>
            </div>
          </div>
          <div class="grid gap-4 lg:grid-cols-2">
            <label class="form-control">
              <span class="label-text">摘要</span>
              <textarea class="textarea textarea-bordered min-h-28 rounded-xl" name="excerpt"></textarea>
            </label>
            <label class="form-control">
              <span class="label-text">封面图地址</span>
              <div class="join w-full">
                <input class="input join-item input-bordered w-full rounded-l-xl" name="cover_image" placeholder="/image1.webp 或 /uploads/..." />
                <button class="btn join-item" type="button" data-pick-media data-target-form="article-form" data-target-field="cover_image" data-media-type="image">选择</button>
                <label class="btn join-item rounded-r-xl">
                  上传
                  <input id="cover-upload" class="hidden" type="file" accept="image/*" />
                </label>
              </div>
              <div id="cover-preview" class="mt-3 hidden overflow-hidden rounded-xl border border-base-content/10 bg-base-200"></div>
              <div class="mt-3 flex gap-4">
                <label class="label cursor-pointer justify-start gap-2"><input class="checkbox checkbox-sm" type="checkbox" name="is_pinned" />置顶</label>
                <label class="label cursor-pointer justify-start gap-2"><input class="checkbox checkbox-sm" type="checkbox" name="is_recommended" />推荐</label>
              </div>
            </label>
          </div>
          <label class="form-control">
            <span class="label-text">正文 Markdown</span>
            <div class="my-2 flex flex-wrap gap-2" id="markdown-toolbar">
              <button class="btn btn-xs rounded-lg" type="button" data-md-insert="heading">标题</button>
              <button class="btn btn-xs rounded-lg" type="button" data-md-insert="bold">加粗</button>
              <button class="btn btn-xs rounded-lg" type="button" data-md-insert="quote">引用</button>
              <button class="btn btn-xs rounded-lg" type="button" data-md-insert="code">代码块</button>
              <button class="btn btn-xs rounded-lg" type="button" data-md-insert="table">表格</button>
              <button class="btn btn-xs rounded-lg" type="button" data-md-insert="image">图片</button>
              <button class="btn btn-xs rounded-lg" type="button" data-md-insert="math">公式</button>
              <button class="btn btn-xs rounded-lg" type="button" data-md-insert="footnote">脚注</button>
            </div>
            <textarea class="textarea textarea-bordered min-h-[22rem] rounded-xl font-mono text-sm" name="content" required></textarea>
          </label>
          <p id="editor-message" class="min-h-6 text-sm"></p>
        </form>
      </section>

      <section id="media-panel" class="admin-panel hidden">
        <div class="ryu-card p-5">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <h2 class="text-2xl font-black">媒体资源</h2>
              <p class="text-sm text-base-content/50">本地存储，支持图片、音频、视频和常用文件。</p>
            </div>
            <div class="flex flex-wrap gap-2">
              <select id="media-type-filter" class="select select-bordered select-sm rounded-xl">
                <option value="">全部文件</option>
                <option value="image">图片</option>
                <option value="audio">音频</option>
                <option value="video">视频</option>
                <option value="font">字体</option>
              </select>
              <button id="media-normal-mode" class="ryu-btn btn-sm" type="button">媒体库</button>
              <button id="media-trash-mode" class="ryu-btn btn-sm" type="button">回收站</button>
              <label class="ryu-btn-primary btn-sm">
                上传文件
                <input id="media-upload" class="hidden" type="file" multiple />
              </label>
              <button id="cleanup-media" class="ryu-btn btn-sm">清理冗余</button>
              <button id="empty-media-trash" class="ryu-btn btn-sm hidden" type="button">清空未引用</button>
            </div>
          </div>
          <div id="media-message" class="mt-3 min-h-6 text-sm"></div>
          <div id="media-grid" class="admin-media-grid mt-5"></div>
        </div>
      </section>

      <section id="fonts-panel" class="admin-panel hidden">
        <div class="grid gap-4 lg:grid-cols-[1fr_1.2fr]">
          <form id="font-library-form" class="ryu-card grid gap-4 p-5">
            <div>
              <h2 class="text-2xl font-black">字体库</h2>
              <p class="text-sm text-base-content/50">统一上传和维护字体文件，写作页和文章编辑只负责选择字体。</p>
            </div>
            <label class="form-control">
              <span class="label-text">字体名称</span>
              <input class="input input-bordered rounded-xl" id="font-name-input" placeholder="例如：霞鹜文楷 / 思源宋体" />
            </label>
            <label class="form-control">
              <span class="label-text">字体文件</span>
              <div class="join w-full">
                <input class="input join-item input-bordered w-full rounded-l-xl" id="font-url-input" placeholder="/uploads/... 或 https://..." />
                <label class="btn join-item rounded-r-xl">上传<input id="font-file-upload" class="hidden" type="file" accept=".woff,.woff2,.ttf,.otf,.eot,font/*" /></label>
              </div>
            </label>
            <div class="flex flex-wrap gap-2">
              <button id="add-font-library" class="ryu-btn-primary" type="button">加入字体库</button>
              <button id="save-font-library" class="ryu-btn" type="button">保存字体库</button>
            </div>
            <p id="font-library-message" class="min-h-6 text-sm"></p>
          </form>
          <div class="ryu-card p-5">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div>
                <h3 class="text-xl font-black">已导入字体</h3>
                <p class="text-sm text-base-content/50">可在媒体库筛选“字体”，把已上传字体加入这里；删除后记得保存字体库。</p>
              </div>
            </div>
            <div id="font-library-list" class="mt-5 grid gap-3 text-sm"></div>
          </div>
        </div>
      </section>

      <section id="backup-panel" class="admin-panel hidden">
        <div class="ryu-card p-5">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <h2 class="text-2xl font-black">备份与恢复</h2>
              <p class="text-sm text-base-content/50">导出或恢复 SQLite 数据库和文章数据。媒体文件仍保存在 uploads 目录。</p>
            </div>
            <button id="refresh-backup-manifest" class="ryu-btn btn-sm" type="button">刷新清单</button>
          </div>
          <div class="mt-5 grid gap-4 md:grid-cols-3">
            <button class="ryu-btn-primary min-h-24 flex-col" type="button" data-download-backup="database">
              <strong>数据库备份</strong>
              <span class="text-xs opacity-75">下载 .db 文件</span>
            </button>
            <button class="ryu-btn min-h-24 flex-col" type="button" data-download-backup="articles">
              <strong>文章导出</strong>
              <span class="text-xs opacity-75">Markdown JSON</span>
            </button>
            <button class="ryu-btn min-h-24 flex-col" type="button" data-download-backup="manifest">
              <strong>备份清单</strong>
              <span class="text-xs opacity-75">设置和数量</span>
            </button>
          </div>
          <div class="mt-6 border-t border-base-content/10 pt-5">
            <div>
              <h3 class="text-lg font-black">导入恢复</h3>
              <p class="text-sm text-base-content/50">数据库恢复会替换业务数据并自动保留恢复前快照；文章导入按 slug 新建或更新。</p>
            </div>
            <div class="mt-4 grid gap-3 md:grid-cols-2">
              <label class="flex min-h-24 cursor-pointer items-center justify-between gap-4 rounded-2xl border border-error/20 bg-error/5 p-4 transition hover:border-error/40">
                <span>
                  <strong class="block">恢复数据库</strong>
                  <span class="text-xs text-base-content/55">选择 .db / .sqlite 文件</span>
                </span>
                <span class="ryu-btn btn-sm">选择文件</span>
                <input id="database-import-input" class="hidden" type="file" accept=".db,.sqlite,.sqlite3,application/x-sqlite3" />
              </label>
              <label class="flex min-h-24 cursor-pointer items-center justify-between gap-4 rounded-2xl border border-base-content/10 bg-base-200/45 p-4 transition hover:border-primary/35">
                <span>
                  <strong class="block">导入文章</strong>
                  <span class="text-xs text-base-content/55">选择文章导出的 JSON 文件</span>
                </span>
                <span class="ryu-btn btn-sm">选择文件</span>
                <input id="articles-import-input" class="hidden" type="file" accept=".json,application/json" />
              </label>
            </div>
            <p class="mt-3 text-xs text-warning">恢复数据库不会自动补回已从磁盘永久删除的媒体文件，请同时保留 uploads 目录。</p>
          </div>
          <p id="backup-message" class="mt-4 min-h-6 text-sm"></p>
          <pre id="backup-manifest" class="mt-4 max-h-96 overflow-auto rounded-2xl bg-base-200/70 p-4 text-xs"></pre>
        </div>
      </section>

      <section id="music-panel" class="admin-panel hidden">
        <div class="grid gap-4 lg:grid-cols-[1fr_1.2fr]">
          <form id="music-form" class="ryu-card grid gap-4 p-5">
            <div>
              <h2 class="text-2xl font-black">音乐组件</h2>
              <p class="text-sm text-base-content/50">上传音乐和封面，保存为全站播放列表。</p>
            </div>
            <label class="form-control">
              <span class="label-text">歌曲名</span>
              <input class="input input-bordered rounded-xl" name="title" required />
            </label>
            <label class="form-control">
              <span class="label-text">歌手</span>
              <input class="input input-bordered rounded-xl" name="artist" placeholder="未知歌手" />
            </label>
            <label class="form-control">
              <span class="label-text">音乐地址</span>
              <input class="input input-bordered rounded-xl mb-3" name="playlist" placeholder="合集 / 歌单名，默认歌单" />
              <div class="join w-full">
                <input class="input join-item input-bordered w-full rounded-l-xl" name="url" placeholder="/uploads/..." required />
                <button class="btn join-item" type="button" data-pick-media data-target-form="music-form" data-target-field="url" data-media-type="audio">选择</button>
                <label class="btn join-item rounded-r-xl">
                  上传
                  <input id="music-audio-upload" class="hidden" type="file" accept="audio/*" />
                </label>
              </div>
            </label>
            <label class="form-control">
              <span class="label-text">封面地址</span>
              <div class="join w-full">
                <input class="input join-item input-bordered w-full rounded-l-xl" name="cover" placeholder="/uploads/..." />
                <button class="btn join-item" type="button" data-pick-media data-target-form="music-form" data-target-field="cover" data-media-type="image">选择</button>
                <label class="btn join-item rounded-r-xl">
                  上传
                  <input id="music-cover-upload" class="hidden" type="file" accept="image/*" />
                </label>
              </div>
            </label>
            <label class="form-control">
              <span class="label-text">歌词</span>
              <textarea class="textarea textarea-bordered min-h-36 rounded-xl" name="lyrics" placeholder="支持逐行歌词，也可以粘贴 LRC 文本"></textarea>
            </label>
            <button class="ryu-btn-primary" type="submit">添加到播放列表</button>
            <p id="music-message" class="min-h-6 text-sm"></p>
          </form>
          <div class="ryu-card p-5">
            <div class="flex items-center justify-between gap-3">
              <h3 class="text-xl font-black">歌单管理</h3>
              <button class="ryu-btn btn-sm" type="button" id="reset-music-playlist">新建歌单</button>
            </div>
            <form id="music-playlist-form" class="mt-4 grid gap-3">
              <input type="hidden" name="id" />
              <input class="input input-bordered rounded-xl" name="name" placeholder="歌单名称" required />
              <input class="input input-bordered rounded-xl" name="description" placeholder="歌单描述" />
              <div class="join w-full">
                <input class="input join-item input-bordered w-full rounded-l-xl" name="cover" placeholder="歌单封面 /uploads/..." />
                <button class="btn join-item" type="button" data-pick-media data-target-form="music-playlist-form" data-target-field="cover" data-media-type="image">选择</button>
              </div>
              <div class="grid gap-3 md:grid-cols-[1fr_auto]">
                <input class="input input-bordered rounded-xl" name="sort_order" type="number" placeholder="排序" />
