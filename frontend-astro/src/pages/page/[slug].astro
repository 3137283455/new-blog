---
import BaseLayout from '@layouts/BaseLayout.astro'
import { getPage } from '../../lib/api'

const slug = Astro.params.slug || ''
const page = await getPage(slug)

if (!page) {
  return Astro.redirect('/404')
}

const templateLabels: Record<string, string> = {
  default: '独立页面',
  about: '关于我',
  guestbook: '留言板',
  projects: '项目展示',
  disclaimer: '免责声明',
}
---

<BaseLayout title={page.title} subtitle={templateLabels[page.template || 'default'] || '自定义独立页面'} showSidebar={false}>
  <article class={`custom-page custom-page-${page.template || 'default'} ryu-card p-6 md:p-8`}>
    <header class="mb-6 border-b border-base-content/10 pb-5">
      <p class="text-sm font-black uppercase text-primary">{templateLabels[page.template || 'default'] || 'PAGE'}</p>
      <h1 class="mt-2 text-3xl font-black md:text-5xl">{page.title}</h1>
    </header>
    <div class="prose prose-lg max-w-none" set:html={page.content_html || '<p>这个页面还没有内容。</p>'} />
  </article>
</BaseLayout>
