    <script is:inline src="/admin-write-utils.js"></script>
    <script is:inline>
      // @ts-nocheck
      const API_BASE = document.body.dataset.apiBase || '/api'
      const tokenKey = 'boke_admin_token'
      const token = localStorage.getItem(tokenKey) || ''
      const params = new URLSearchParams(location.search)
      let articleId = params.get('id') || ''
      let articles = []
      let trashedArticles = []
      let currentFilter = 'all'
      let previewEnabled = false
      let previewSplit = 52
      let fontLibrary = []
      let previewRequestId = 0
      let isDirty = false
      let autosaveTimer = null

      const $ = (selector) => document.querySelector(selector)
      const $$ = (selector) => Array.from(document.querySelectorAll(selector))
      const writerUtils = window.WriterUtils || {}

      function setMessage(text) {
        $('#save-status').textContent = text || 'жңӘдҝқеӯҳ'
      }

      function autosaveKey(id = articleId) {
        return `boke_writer_autosave_${id || 'new'}`
      }

      function collectLocalDraft() {
        return {
          articleId,
          title: $('#title')?.value || '',
          content: $('#content')?.value || '',
          excerpt: $('#excerpt')?.value || '',
          cover: $('#cover')?.value || '',
          status: $('#status')?.value || 'draft',
          visibility: $('#visibility')?.value || 'public',
          category: $('#category')?.value || '',
          titleFont: $('#title-font-select')?.value || '',
          bodyFont: $('#body-font-select')?.value || '',
          isPinned: !!$('#is-pinned')?.checked,
          isRecommended: !!$('#is-recommended')?.checked,
          updatedAt: Date.now(),
        }
      }

      function applyLocalDraft(draft) {
        if (!draft) return
        $('#title').value = draft.title || ''
        $('#content').value = draft.content || ''
        $('#excerpt').value = draft.excerpt || ''
        $('#cover').value = draft.cover || ''
        $('#status').value = draft.status || 'draft'
        $('#quick-status').value = draft.status || 'draft'
        $('#visibility').value = draft.visibility || 'public'
        $('#category').value = draft.category || ''
        $('#title-font-select').value = draft.titleFont || ''
        $('#body-font-select').value = draft.bodyFont || ''
        $('#is-pinned').checked = !!draft.isPinned
        $('#is-recommended').checked = !!draft.isRecommended
        updateWordCount()
        applyArticleFonts()
      }

      function markDirty() {
        isDirty = true
        window.clearTimeout(autosaveTimer)
        autosaveTimer = window.setTimeout(() => {
          const draft = collectLocalDraft()
          localStorage.setItem(autosaveKey(), JSON.stringify(draft))
          setMessage(`е·Іжң¬ең°иҮӘеҠЁдҝқеӯҳ ${new Date(draft.updatedAt).toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })}`)
        }, 5000)
      }

      function clearLocalDraft(id = articleId) {
        localStorage.removeItem(autosaveKey(id))
      }

      function restoreLocalDraftIfNeeded() {
        const raw = localStorage.getItem(autosaveKey())
        if (!raw) return
        try {
          const draft = JSON.parse(raw)
          if (!draft?.updatedAt) return
          const label = new Date(draft.updatedAt).toLocaleString('zh-CN')
          if (confirm(`жЈҖжөӢеҲ° ${label} зҡ„жң¬ең°дёҙж—¶зЁҝпјҢжҳҜеҗҰжҒўеӨҚпјҹ`)) {
            applyLocalDraft(draft)
            isDirty = true
            setMessage('е·ІжҒўеӨҚжң¬ең°дёҙж—¶зЁҝ')
          }
        } catch {
          clearLocalDraft()
        }
      }

      function html(value) {
        return writerUtils.html(value)
      }

      function cssString(value = '') {
        return writerUtils.cssString(value)
      }

      function cssUrl(value = '') {
        return writerUtils.cssUrl(value)
      }

      function fontStyleBlock() {
        return writerUtils.fontStyleBlock(fontLibrary)
      }

      function ensureWriterFontStyle() {
        let style = document.getElementById('writer-font-library-style')
        if (!style) {
          style = document.createElement('style')
          style.id = 'writer-font-library-style'
          document.head.appendChild(style)
        }
        style.textContent = fontStyleBlock()
      }

      function fontFamilyCss(font) {
        return writerUtils.fontFamilyCss(font)
      }

      function applyArticleFonts() {
        const titleFont = parseFontSelection($('#title-font-select')?.value || '')
        const bodyFont = parseFontSelection($('#body-font-select')?.value || '')
        const titleFamily = fontFamilyCss(titleFont)
        const bodyFamily = fontFamilyCss(bodyFont)
        $('#title').style.fontFamily = titleFamily || ''
        $('#content').style.fontFamily = bodyFamily || ''
        if (previewEnabled) updatePreview()
      }

      function parseSetting(row) {
        return writerUtils.parseSetting(row)
      }

      function fontKey(font) {
        return writerUtils.fontKey(font)
      }

      function parseFontSelection(value) {
        return writerUtils.parseFontSelection(value)
      }

      function renderFontSelectors() {
        const options = ['<option value="">й»ҳи®Өеӯ—дҪ“</option>']
          .concat(fontLibrary.map((font) => {
            const family = font.family || font.name || ''
            const url = font.url || ''
            if (!family || !url) return ''
            return `<option value="${html(fontKey({ family, url }))}">${html(family)}</option>`
          }))
          .filter(Boolean)
          .join('')
        $('#title-font-select').innerHTML = options
        $('#body-font-select').innerHTML = options
        $('#inline-font-select').innerHTML = '<option value="">еӯ—дҪ“</option><option value="__clear">еҸ–ж¶Ҳеӯ—дҪ“</option>' + options.replace('<option value="">й»ҳи®Өеӯ—дҪ“</option>', '')
        ensureWriterFontStyle()
      }

      async function loadFontLibrary() {
        try {
          const json = await request('/admin/settings')
          const rows = json.data || []
          const settings = Object.fromEntries(rows.map((item) => [item.key, parseSetting(item)]))
          fontLibrary = Array.isArray(settings.font_library) ? settings.font_library : []
        } catch {
          fontLibrary = []
        }
        renderFontSelectors()
      }

      function renderInlineMarkdown(value) {
        return writerUtils.renderInlineMarkdown(value)
      }

      function markdownToHtml(markdown) {
        return writerUtils.markdownToHtml(markdown)
      }

      async function updatePreview() {
        const requestId = ++previewRequestId
        const title = $('#title').value.trim()
        const content = $('#content').value
        const fontCss = fontStyleBlock()
        const titleFont = parseFontSelection($('#title-font-select')?.value || '')
        const bodyFont = parseFontSelection($('#body-font-select')?.value || '')
        let contentHtml = markdownToHtml(content)
        try {
          const json = await request('/admin/markdown/preview', {
            method: 'POST',
            body: JSON.stringify({ content }),
          })
          contentHtml = json.data?.html || ''
        } catch {
          // Keep the local renderer as a fallback when the API is temporarily unavailable.
        }
        if (requestId !== previewRequestId) return
        $('#preview-panel').innerHTML = writerUtils.buildPreviewHtml({ title, contentHtml, fontCss, titleFont, bodyFont })
      }

      async function request(path, options = {}) {
        if (!token) {
          setMessage('иҜ·е…ҲеӣһеҗҺеҸ°зҷ»еҪ•')
          throw new Error('иҜ·е…Ҳзҷ»еҪ•еҗҺеҸ°')
        }
        const headers = {
          Authorization: `Bearer ${token}`,
          ...(options.headers || {}),
        }
        if (!(options.body instanceof FormData)) headers['Content-Type'] = 'application/json'
        let res
        try {
          res = await fetch(`${API_BASE}${path}`, { ...options, headers })
        } catch {
          throw new Error(`ж— жі•иҝһжҺҘеҗҺз«Ҝ APIпјҲ${API_BASE}пјүпјҢиҜ·зЎ®и®Ө Express жңҚеҠЎе·ІеҗҜеҠЁдё”д»ЈзҗҶй…ҚзҪ®жӯЈеёё`)
        }
        const json = await res.json().catch(() => ({}))
        if (!res.ok || json.success === false) throw new Error(json.message || `иҜ·жұӮеӨұиҙҘпјҲHTTP ${res.status}пјү`)
        return json
      }

      async function publicRequest(path) {
        try {
          const res = await fetch(`${API_BASE}${path}`)
          if (!res.ok) return { data: [] }
          return res.json()
        } catch {
          return { data: [] }
        }
      }

      async function uploadFile(file, message = 'дёҠдј дёӯ...') {
        if (!file) return null
        setMessage(message)
        const form = new FormData()
        form.append('file', file)
        const json = await request('/admin/media/upload', { method: 'POST', body: form })
        return json.data
      }

      function collectPayload(statusOverride) {
        const titleFont = parseFontSelection($('#title-font-select').value)
        const bodyFont = parseFontSelection($('#body-font-select').value)
        return {
          title: $('#title').value.trim(),
          content: $('#content').value.trim(),
          excerpt: $('#excerpt').value.trim(),
          cover_image: $('#cover').value.trim(),
          title_font_family: titleFont.family,
          title_font_url: titleFont.url,
          body_font_family: bodyFont.family,
          body_font_url: bodyFont.url,
          status: statusOverride || $('#status').value,
          visibility: $('#visibility').value,
          category_id: $('#category').value ? Number($('#category').value) : null,
          tag_ids: Array.from($('#tags').selectedOptions).map((option) => Number(option.value)),
          is_pinned: $('#is-pinned').checked,
          is_recommended: $('#is-recommended').checked,
        }
      }

      function fillArticle(post) {
        articleId = post?.id ? String(post.id) : ''
        $('#writer-mode').textContent = articleId ? 'зј–иҫ‘ж–Үз« ' : 'ж–°ж–Үз« '
        $('#title').value = post?.title || ''
        $('#content').value = post?.content || ''
        $('#excerpt').value = post?.excerpt || ''
        $('#cover').value = post?.cover_image || ''
        $('#status').value = post?.status || 'draft'
        $('#quick-status').value = post?.status || 'draft'
        $('#visibility').value = post?.visibility || 'public'
        $('#category').value = post?.category_id || ''
        $('#title-font-select').value = fontKey({ family: post?.title_font_family, url: post?.title_font_url })
        $('#body-font-select').value = fontKey({ family: post?.body_font_family, url: post?.body_font_url })
        $('#is-pinned').checked = !!post?.is_pinned
        $('#is-recommended').checked = !!post?.is_recommended
        const tagIds = new Set((post?.tags || []).map((tag) => String(tag.id)))
        Array.from($('#tags').options).forEach((option) => {
          option.selected = tagIds.has(option.value)
        })
        updateWordCount()
        applyArticleFonts()
        isDirty = false
        renderArticleList()
      }

      async function saveArticle(statusOverride) {
        const payload = collectPayload(statusOverride)
        if (!payload.title) {
          setMessage('иҜ·е…ҲеЎ«еҶҷж Үйўҳ')
          return
        }
        if (!payload.content) {
          setMessage('иҜ·е…ҲеЎ«еҶҷжӯЈж–Ү')
          return
        }
        setMessage('жӯЈеңЁдҝқеӯҳ...')
        try {
          const json = await request(articleId ? `/admin/articles/${articleId}` : '/admin/articles', {
            method: articleId ? 'PUT' : 'POST',
            body: JSON.stringify(payload),
          })
          const oldArticleId = articleId
          if (!articleId && json.data?.id) articleId = String(json.data.id)
          clearLocalDraft(oldArticleId)
          clearLocalDraft(articleId)
          isDirty = false
          setMessage(payload.status === 'published' ? 'е·ІеҸ‘еёғ' : 'е·ІдҝқеӯҳиҚүзЁҝ')
          await loadArticles()
        } catch (error) {
          setMessage(error.message || 'дҝқеӯҳеӨұиҙҘ')
        }
      }

      function insertText(before, text, after = '') {
        const textarea = $('#content')
        const start = textarea.selectionStart || 0
        const end = textarea.selectionEnd || start
        const selected = textarea.value.slice(start, end) || text
        textarea.setRangeText(`${before}${selected}${after}`, start, end, 'end')
        textarea.focus()
        updateWordCount()
        updatePreview()
      }

      function unwrapInlineFont(value) {
        return writerUtils.unwrapInlineFont(value)
      }

      function inlineFontRangeAt(value, start, end) {
        return writerUtils.inlineFontRangeAt(value, start, end)
      }

      function clearInlineFont() {
        const textarea = $('#content')
        const start = textarea.selectionStart || 0
        const end = textarea.selectionEnd || start
        const value = textarea.value
        const selected = value.slice(start, end)
        const enclosing = inlineFontRangeAt(value, start, end)

        if (enclosing && (start === end || selected.includes('<span') || selected.includes('</span>'))) {
          textarea.setRangeText(enclosing.text, enclosing.start, enclosing.end, 'select')
          setMessage('е·Із§»йҷӨеұҖйғЁеӯ—дҪ“')
        } else if (selected) {
          const cleaned = unwrapInlineFont(selected)
          textarea.setRangeText(cleaned, start, end, 'select')
          setMessage(cleaned === selected ? 'йҖүдёӯеҶ…е®№жІЎжңүеұҖйғЁеӯ—дҪ“ж Үзӯҫ' : 'е·Із§»йҷӨйҖүдёӯеҶ…е®№зҡ„еұҖйғЁеӯ—дҪ“')
        } else {
          setMessage('иҜ·йҖүдёӯеҶ…е®№пјҢжҲ–жҠҠе…үж Үж”ҫеңЁе·ІжңүеұҖйғЁеӯ—дҪ“ж–Үеӯ—дёӯ')
          textarea.focus()
          return
        }

        textarea.focus()
        updateWordCount()
        updatePreview()
      }

      function applyInlineFont() {
        const select = $('#inline-font-select')
        if (select.value === '__clear') {
          clearInlineFont()
          select.value = ''
          return
        }
        const font = parseFontSelection(select.value)
        const textarea = $('#content')
        const start = textarea.selectionStart || 0
        const end = textarea.selectionEnd || start
        const selected = textarea.value.slice(start, end)

        if (!selected) {
          setMessage('иҜ·е…ҲйҖүдёӯиҰҒжӣҙжҚўеӯ—дҪ“зҡ„ж–Үеӯ—')
          select.value = ''
          textarea.focus()
          return
        }

        const cleanSelected = selected.replace(/<span\s+data-font="[^"]+"(?:\s+data-font-url="[^"]+")?>([\s\S]*?)<\/span>/g, '$1')
        if (!font.family) {
          textarea.setRangeText(cleanSelected, start, end, 'select')
          setMessage('е·Із§»йҷӨйҖүдёӯж–Үеӯ—зҡ„еұҖйғЁеӯ—дҪ“')
        } else {
          textarea.setRangeText(`<span data-font="${html(font.family)}" data-font-url="${html(font.url)}">${cleanSelected}</span>`, start, end, 'select')
          setMessage(`е·Іеә”з”ЁеұҖйғЁеӯ—дҪ“пјҡ${font.family}`)
          if (!previewEnabled) setPreviewState(true)
        }

        select.value = ''
        textarea.focus()
        updateWordCount()
        updatePreview()
      }

      function insertMarkdown(kind) {
        const headingLevel = Math.max(1, Math.min(6, Number($('#heading-level')?.value || 2)))
        const snippets = {
          heading: [`\n${'#'.repeat(headingLevel)} `, `H${headingLevel} ж Үйўҳ`, '\n'],
          bold: ['**', 'йҮҚзӮ№ж–Үеӯ—', '**'],
          italic: ['*', 'ж–ңдҪ“ж–Үеӯ—', '*'],
          strike: ['~~', 'еҲ йҷӨзәҝж–Үеӯ—', '~~'],
          hr: ['\n\n', '---', '\n\n'],
          task: ['\n- [ ] ', 'еҫ…еҠһдәӢйЎ№', '\n'],
          ordered: ['\n1. ', 'з¬¬дёҖйЎ№', '\n2. з¬¬дәҢйЎ№\n'],
          unordered: ['\n- ', 'еҲ—иЎЁйЎ№', '\n- еҸҰдёҖйЎ№\n'],
          quote: ['\n> ', 'еј•з”ЁеҶ…е®№', '\n'],
          code: ['\n```js\n', 'console.log("Hello")', '\n```\n'],
          inlineCode: ['`', 'code', '`'],
          link: ['[', 'й“ҫжҺҘж–Үеӯ—', '](https://example.com)'],
          table: ['\n| еҲ—дёҖ | еҲ—дәҢ |\n| --- | --- |\n| ', 'еҶ…е®№', ' | еҶ…е®№ |\n'],
          math: ['\n$$\n', 'E = mc^2', '\n$$\n'],
          footnote: ['', 'йңҖиҰҒиҜҙжҳҺзҡ„ж–Үеӯ—[^1]\n\n[^1]: и„ҡжіЁеҶ…е®№', ''],
        }
        const item = snippets[kind]
        if (!item) return
        insertText(item[0], item[1], item[2])
      }

      function importTextFile(file) {
        if (!file) return
        const allowed = /\.(txt|md|markdown)$/i.test(file.name) || /^text\//i.test(file.type || '')
        if (!allowed) {
          setMessage('еҸӘж”ҜжҢҒ txtгҖҒmdгҖҒmarkdown ж–Үжң¬ж–Үд»¶')
          return
        }
        const reader = new FileReader()
        reader.onload = () => {
          const text = String(reader.result || '').replace(/^\uFEFF/, '')
          const titleFromFile = file.name.replace(/\.(txt|md|markdown)$/i, '')
          if (!$('#title').value.trim()) $('#title').value = titleFromFile
          $('#content').value = $('#content').value.trim()
            ? `${$('#content').value.trimEnd()}\n\n${text}`
            : text
          updateWordCount()
          updatePreview()
          setMessage(`е·ІеҜје…Ҙпјҡ${file.name}`)
        }
        reader.onerror = () => setMessage('ж–Үжң¬иҜ»еҸ–еӨұиҙҘ')
        reader.readAsText(file, 'utf-8')
      }

      function updateWordCount() {
        const text = `${$('#title').value}\n${$('#content').value}`
        $('#word-count').textContent = `жң¬з« еӯ—ж•°пјҡ${text.replace(/\s/g, '').length}`
      }

      function getVisibleArticles() {
        const keyword = $('#article-search').value.trim().toLowerCase()
        const pool = currentFilter === 'trash' ? trashedArticles : articles
        return pool.filter((post) => {
          const matchFilter =
            currentFilter === 'all' ||
            currentFilter === 'trash' ||
            (currentFilter === 'draft' && post.status !== 'published') ||
            (currentFilter === 'published' && post.status === 'published')
          const matchKeyword = !keyword || `${post.title} ${post.slug} ${post.excerpt || ''}`.toLowerCase().includes(keyword)
          return matchFilter && matchKeyword
        })
      }

      function renderTabs() {
        const counts = {
          all: articles.length,
          draft: articles.filter((post) => post.status !== 'published').length,
          published: articles.filter((post) => post.status === 'published').length,
          trash: trashedArticles.length,
        }
        const labels = { all: 'е…ЁйғЁ', draft: 'иҚүзЁҝз®ұ', published: 'е·ІеҸ‘еёғ', trash: 'еӣһж”¶з«ҷ' }
        $$('#article-tabs .writer-tab').forEach((button) => {
          const filter = button.dataset.filter
          button.classList.toggle('active', filter === currentFilter)
          button.textContent = `${labels[filter]} ${counts[filter]}`
        })
      }

      function renderArticleList() {
        renderTabs()
        const visible = getVisibleArticles()
        const emptyText = {
          all: 'иҝҳжІЎжңүж–Үз« пјҢзӮ№дёҠж–№вҖңж–°е»әж–Үз« вҖқејҖе§ӢеҶҷгҖӮ',
          draft: 'иҚүзЁҝз®ұйҮҢжҡӮж—¶жІЎжңүж–Үз« гҖӮ',
          published: 'иҝҳжІЎжңүе·ІеҸ‘еёғж–Үз« гҖӮ',
          trash: 'еӣһж”¶з«ҷдёәз©әгҖӮ',
        }[currentFilter] || 'иҝҷйҮҢжҡӮж—¶жІЎжңүж–Үз« '
        $('#article-list').innerHTML = visible.length
          ? visible.map(renderArticleItem).join('')
          : `<div class="writer-empty">${html(emptyText)}</div>`
      }

      function renderArticleItem(post) {
        const isTrash = !!post.deleted_at || currentFilter === 'trash'
        const status = isTrash ? 'еӣһж”¶з«ҷ' : (post.status === 'published' ? 'е·ІеҸ‘еёғ' : 'иҚүзЁҝ')
        const statusKey = isTrash ? 'trash' : (post.status === 'published' ? 'published' : 'draft')
        const date = isTrash
          ? `еҲ йҷӨдәҺ ${post.deleted_at || post.updated_at || post.created_at || ''}`
          : (post.updated_at || post.created_at || '')
        return `
          <article class="writer-post ${String(post.id) === String(articleId) ? 'active' : ''}" data-id="${post.id}" data-status="${statusKey}">
            <div class="writer-post-main">
              <div class="writer-post-title">${html(post.title || 'жңӘе‘ҪеҗҚж–Үз« ')}</div>
              <div class="writer-post-meta">
                <span class="writer-pill ${statusKey}">${html(status)}</span>
                <span class="writer-post-time">${html(date)}</span>
              </div>
            </div>
            <div class="writer-post-actions writer-post-menu">
              ${isTrash
                ? `<button class="writer-mini" type="button" data-action="restore" data-id="${post.id}">жҒўеӨҚ</button>
                   <button class="writer-mini danger" type="button" data-action="force-delete" data-id="${post.id}">ж°ёд№…еҲ йҷӨ</button>`
                : `<a class="writer-mini" href="/admin/write?id=${post.id}">зј–иҫ‘</a>
                   <button class="writer-mini danger" type="button" data-action="delete" data-id="${post.id}">еҲ йҷӨ</button>`}
            </div>
          </article>
        `
      }

      async function loadArticles() {
        const [normalJson, trashJson] = await Promise.all([
          request('/admin/articles?pageSize=200'),
          request('/admin/articles?trashed=true&pageSize=200'),
        ])
        articles = normalJson.data || []
        trashedArticles = trashJson.data || []
        renderArticleList()
      }

      async function loadTaxonomy() {
        const [categoryJson, tagJson] = await Promise.all([
          publicRequest('/categories'),
          publicRequest('/tags'),
        ])
        $('#category').innerHTML = '<option value="">ж— еҲҶзұ»</option>' + (categoryJson.data || []).map((item) => (
          `<option value="${item.id}">${html(item.name)}</option>`
        )).join('')
        $('#tags').innerHTML = (tagJson.data || []).map((item) => (
          `<option value="${item.id}">${html(item.name)}</option>`
        )).join('')
      }

      async function loadCurrentArticle() {
        if (!articleId) {
          fillArticle(null)
          return
        }
        const json = await request(`/admin/articles/${articleId}`)
        fillArticle(json.data)
      }

      async function deleteArticle(id) {
        if (!confirm('зЎ®е®ҡжҠҠиҝҷзҜҮж–Үз« з§»е…Ҙеӣһж”¶з«ҷеҗ—пјҹ')) return
        await request(`/admin/articles/${id}`, { method: 'DELETE' })
        if (String(id) === String(articleId)) {
          history.pushState(null, '', '/admin/write')
          fillArticle(null)
        }
        setMessage('е·Із§»е…Ҙеӣһж”¶з«ҷ')
        await loadArticles()
      }

      async function restoreArticle(id) {
        await request(`/admin/articles/${id}/restore`, { method: 'PUT' })
        setMessage('е·ІжҒўеӨҚж–Үз« ')
        await loadArticles()
      }

      async function forceDeleteArticle(id) {
        if (!confirm('зЎ®е®ҡж°ёд№…еҲ йҷӨеҗ—пјҹиҝҷдёӘж“ҚдҪңдёҚиғҪж’Өй”ҖгҖӮ')) return
        await request(`/admin/articles/${id}/force`, { method: 'DELETE' })
        if (String(id) === String(articleId)) {
          history.pushState(null, '', '/admin/write')
          fillArticle(null)
        }
        setMessage('е·Іж°ёд№…еҲ йҷӨ')
        await loadArticles()
      }

      function setPreviewState(enabled) {
        previewEnabled = enabled
        document.body.classList.toggle('preview-on', previewEnabled)
        $('#toggle-preview')?.classList.toggle('active', previewEnabled)
        if (previewEnabled) {
          setPreviewSplit(previewSplit)
          updatePreview()
        }
      }

      function setPreviewSplit(value) {
        previewSplit = Math.max(28, Math.min(72, Number(value) || 52))
        document.documentElement.style.setProperty('--preview-split', `${previewSplit}%`)
      }

      function startPreviewResize(event) {
        if (!previewEnabled) return
        event.preventDefault()
        const wrap = event.currentTarget.closest('.writer-paper-wrap')
        const rect = wrap.getBoundingClientRect()
        document.body.classList.add('resizing-preview')

        const onMove = (moveEvent) => {
          const raw = ((moveEvent.clientX - rect.left) / rect.width) * 100
          setPreviewSplit(document.body.classList.contains('preview-left') ? 100 - raw : raw)
        }
        const onUp = () => {
          document.body.classList.remove('resizing-preview')
          window.removeEventListener('mousemove', onMove)
          window.removeEventListener('mouseup', onUp)
        }

        window.addEventListener('mousemove', onMove)
        window.addEventListener('mouseup', onUp)
      }

      function enterImmersive() {
        setPreviewState(true)
        document.body.classList.add('immersive')
        setMessage('жІүжөёжЁЎејҸпјҢжҢү Esc йҖҖеҮә')
      }

      function exitImmersive() {
        document.body.classList.remove('immersive')
        setMessage('е·ІйҖҖеҮәжІүжөёжЁЎејҸ')
      }

      $('#quick-status').addEventListener('change', (event) => {
        $('#status').value = event.target.value
      })
      $('#status').addEventListener('change', (event) => {
        $('#quick-status').value = event.target.value
      })
      $('#toggle-left').addEventListener('click', () => {
        document.body.classList.toggle('left-collapsed')
      })
      $('#toggle-right').addEventListener('click', () => {
        document.body.classList.toggle('right-collapsed')
      })
      $('#toggle-preview').addEventListener('click', () => {
        setPreviewState(!previewEnabled)
      })
      $('#swap-preview').addEventListener('click', () => {
        document.body.classList.toggle('preview-left')
        if (!previewEnabled) setPreviewState(true)
      })
      $('#preview-resizer').addEventListener('mousedown', startPreviewResize)
      $('#immersive-mode').addEventListener('click', enterImmersive)
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && document.body.classList.contains('immersive')) {
          exitImmersive()
        }
      })
      $('#save-draft').addEventListener('click', () => saveArticle('draft'))
      $('#publish-article').addEventListener('click', () => saveArticle('published'))
      $('#import-text-button').addEventListener('click', () => $('#text-file-input').click())
      $('#insert-image-button').addEventListener('click', () => $('#article-image-input').click())
      $('#cover-upload-button').addEventListener('click', () => $('#cover-file-input').click())
      $('#inline-font-select').addEventListener('change', applyInlineFont)
      $('#title-font-select').addEventListener('change', applyArticleFonts)
      $('#body-font-select').addEventListener('change', applyArticleFonts)

      $('#text-file-input').addEventListener('change', (event) => {
        importTextFile(event.target.files?.[0])
        event.target.value = ''
      })
      $('#article-image-input').addEventListener('change', async (event) => {
        try {
          const file = event.target.files?.[0]
          const media = await uploadFile(file, 'жӯЈеңЁдёҠдј жҸ’еӣҫ...')
          if (media?.url) {
            insertText('\n![', file.name.replace(/\.[^.]+$/, '') || 'еӣҫзүҮ', `](${media.url})\n`)
            setMessage('жҸ’еӣҫе·ІжҸ’е…Ҙ')
          }
        } catch (error) {
          setMessage(error.message || 'жҸ’еӣҫдёҠдј еӨұиҙҘ')
        }
        event.target.value = ''
      })
      $('#cover-file-input').addEventListener('change', async (event) => {
        try {
          const media = await uploadFile(event.target.files?.[0], 'жӯЈеңЁдёҠдј е°Ғйқў...')
          if (media?.url) $('#cover').value = media.url
          setMessage('е°Ғйқўе·ІдёҠдј ')
        } catch (error) {
          setMessage(error.message || 'е°ҒйқўдёҠдј еӨұиҙҘ')
        }
        event.target.value = ''
      })
      $('#new-draft').addEventListener('click', () => {
        history.pushState(null, '', '/admin/write')
        fillArticle(null)
        setMessage('ж–°ж–Үз« ')
      })
      $('#article-search').addEventListener('input', renderArticleList)
      $('#content').addEventListener('input', () => {
        updateWordCount()
        markDirty()
        if (previewEnabled) updatePreview()
      })
      $('#title').addEventListener('input', () => {
        updateWordCount()
        markDirty()
        if (previewEnabled) updatePreview()
      })
      ;['excerpt', 'cover', 'status', 'visibility', 'category', 'tags', 'title-font-select', 'body-font-select', 'is-pinned', 'is-recommended'].forEach((id) => {
        document.getElementById(id)?.addEventListener('change', markDirty)
      })
      window.addEventListener('beforeunload', (event) => {
        if (!isDirty) return
        event.preventDefault()
        event.returnValue = ''
      })
      $$('.writer-tool[data-md-insert]').forEach((button) => {
        button.addEventListener('click', () => insertMarkdown(button.dataset.mdInsert))
      })
      $$('#article-tabs .writer-tab').forEach((button) => {
        button.addEventListener('click', () => {
          currentFilter = button.dataset.filter
          renderArticleList()
        })
      })
      $('#article-list').addEventListener('click', async (event) => {
        const target = event.target.closest('[data-action]')
        if (!target) return
        const id = target.dataset.id
        const action = target.dataset.action
        try {
          if (action === 'delete') await deleteArticle(id)
          if (action === 'restore') await restoreArticle(id)
          if (action === 'force-delete') await forceDeleteArticle(id)
        } catch (error) {
          setMessage(error.message || 'ж“ҚдҪңеӨұиҙҘ')
        }
      })

      ;(async () => {
        try {
          await loadTaxonomy()
          await loadFontLibrary()
          await loadArticles()
          await loadCurrentArticle()
          restoreLocalDraftIfNeeded()
          if (articleId) setMessage('е·ІиҪҪе…Ҙж–Үз« ')
        } catch (error) {
          setMessage(error.message || 'еҗҺз«ҜжңӘиҝһжҺҘ')
        }
      })()
    </script>
  </body>
</html>
