---
const apiBase = import.meta.env.PUBLIC_API_BASE || '/api'
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>еҶҷдҪңеҸ°</title>
    <style>
      :root {
        --bg: #f2f3f5;
        --panel: #f7f8fa;
        --paper: #fff;
        --line: #e5e7eb;
        --text: #1f2937;
        --muted: #6b7280;
        --primary: #1677ff;
        --danger: #ef4444;
        --preview-split: 50%;
      }

      * { box-sizing: border-box; }
      html,
      body {
        margin: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
      }
      body {
        min-height: 100%;
        background: var(--bg);
        color: var(--text);
        font-family: Inter, "Microsoft YaHei", "PingFang SC", Arial, sans-serif;
        position: fixed;
        inset: 0;
      }
      button, input, textarea, select { font: inherit; }
      button, a { cursor: pointer; }

      .writer-shell {
        display: grid;
        width: 100%;
        height: 100dvh;
        min-height: 0;
        overflow: hidden;
        grid-template-rows: 3.75rem 1fr 2rem;
      }

      .writer-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        border-bottom: 1px solid var(--line);
        background: rgb(255 255 255 / 0.94);
        padding: 0 1.35rem;
        backdrop-filter: blur(14px);
      }

      .writer-brand,
      .writer-actions,
      .writer-crumbs {
        display: flex;
        align-items: center;
      }

      .writer-brand { gap: 1rem; min-width: 0; }
      .writer-actions { gap: 0.55rem; }
      .writer-crumbs { flex-wrap: wrap; gap: 0.6rem; color: var(--muted); font-size: 0.92rem; }
      .writer-crumbs strong { color: var(--text); }

      .writer-logo {
        display: grid;
        width: 2rem;
        height: 2rem;
        place-items: center;
        border-radius: 0.55rem;
        background: var(--primary);
        color: #fff;
        font-weight: 900;
        text-decoration: none;
      }

      .writer-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.25rem;
        border: 1px solid var(--line);
        border-radius: 0.55rem;
        background: #fff;
        color: var(--text);
        padding: 0 1rem;
        font-weight: 700;
        line-height: 1;
        text-decoration: none;
      }
      .writer-btn.primary { border-color: var(--primary); background: var(--primary); color: #fff; }
      .writer-btn.icon {
        width: 2.25rem;
        padding: 0;
        font-size: 1rem;
      }

      .writer-main {
        display: grid;
        grid-template-columns: 20rem minmax(0, 1fr) 18rem;
        height: 100%;
        min-height: 0;
        overflow: hidden;
      }

      .writer-left,
      .writer-right {
        min-height: 0;
        background: var(--panel);
      }
      .writer-left {
        display: grid;
        grid-template-rows: auto minmax(0, 1fr);
        border-right: 1px solid var(--line);
        overflow: hidden;
      }
      .writer-right {
        border-left: 1px solid var(--line);
        padding: 1rem;
        overflow: auto;
        overscroll-behavior: contain;
      }

      .writer-left-head {
        display: grid;
        gap: 0.75rem;
        padding: 1rem;
        border-bottom: 1px solid var(--line);
      }

      .writer-search {
        width: 100%;
        border: 0;
        border-radius: 0.55rem;
        background: #eef0f2;
        padding: 0.7rem 0.75rem;
        outline: none;
      }

      .writer-left-action {
        border: 0;
        border-radius: 0.55rem;
        background: var(--primary);
        color: #fff;
        padding: 0.72rem 0.9rem;
        text-align: center;
        font-weight: 800;
      }

      .writer-tabs {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.45rem;
      }

      .writer-tab {
        border: 1px solid var(--line);
        border-radius: 0.6rem;
        background: #fff;
        color: var(--muted);
        padding: 0.56rem 0.45rem;
        font-size: 0.82rem;
        font-weight: 800;
      }
      .writer-tab.active {
        border-color: color-mix(in srgb, var(--primary) 34%, white);
        background: #eaf3ff;
        color: var(--primary);
      }

      .writer-list {
        display: grid;
        gap: 0.75rem;
        min-height: 0;
        overflow: auto;
        overscroll-behavior: contain;
        padding: 1rem;
        align-content: start;
      }

      .writer-empty {
        border: 1px dashed var(--line);
        border-radius: 0.8rem;
        padding: 1.2rem;
        color: var(--muted);
        text-align: center;
      }

      .writer-post {
        position: relative;
        display: grid;
        gap: 0.7rem;
        overflow: hidden;
        border: 1px solid #e4e9f2;
        border-radius: 0.95rem;
        background:
          linear-gradient(135deg, rgb(255 255 255 / 0.98), rgb(248 251 255 / 0.94));
        padding: 0.85rem 0.85rem 0.75rem 1rem;
        color: inherit;
        text-align: left;
        text-decoration: none;
        box-shadow: 0 12px 30px rgb(15 23 42 / 0.035);
        transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
      }
      .writer-post::before {
        content: "";
        position: absolute;
        inset: 0 auto 0 0;
        width: 0.22rem;
        background: #a7b2c4;
      }
      .writer-post[data-status="published"]::before { background: #16a34a; }
      .writer-post[data-status="draft"]::before { background: #f59e0b; }
      .writer-post[data-status="trash"]::before { background: #ef4444; }
      .writer-post:hover {
        border-color: color-mix(in srgb, var(--primary) 26%, #dbe4f0);
        box-shadow: 0 14px 36px rgb(15 23 42 / 0.07);
        transform: translateY(-1px);
      }
      .writer-post.active {
        border-color: color-mix(in srgb, var(--primary) 42%, white);
        background:
          linear-gradient(135deg, rgb(236 245 255 / 0.98), rgb(255 255 255 / 0.96));
        box-shadow: 0 14px 34px rgb(22 119 255 / 0.12);
      }
      .writer-post-main {
        display: grid;
        gap: 0.38rem;
        min-width: 0;
      }
      .writer-post-title {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: #172033;
        font-size: 0.96rem;
        font-weight: 900;
        line-height: 1.2;
      }
      .writer-post-meta {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        min-width: 0;
        color: var(--muted);
        font-size: 0.76rem;
      }
      .writer-post-time {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .writer-post-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.4rem;
        flex-wrap: wrap;
      }
      .writer-pill {
        border-radius: 999px;
        background: #eef2ff;
        color: #3158d4;
        padding: 0.16rem 0.46rem;
        font-size: 0.68rem;
        font-weight: 900;
        line-height: 1.25;
      }
      .writer-pill.published { background: #dcfce7; color: #15803d; }
      .writer-pill.draft { background: #fef3c7; color: #b45309; }
      .writer-pill.trash { background: #fee2e2; color: #b91c1c; }
      .writer-post-menu {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.42rem;
      }
      .writer-mini {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 1.9rem;
        border: 1px solid #dce4ef;
        border-radius: 0.62rem;
        background: #fff;
        color: #24324a;
        padding: 0 0.55rem;
        font-size: 0.76rem;
        font-weight: 900;
        text-decoration: none;
        transition: background 0.18s ease, border-color 0.18s ease, color 0.18s ease;
      }
      .writer-mini:hover {
        border-color: color-mix(in srgb, var(--primary) 32%, #dce4ef);
        background: #f3f8ff;
        color: var(--primary);
      }
      .writer-mini.danger {
        border-color: #fee2e2;
        color: var(--danger);
      }
      .writer-mini.danger:hover {
        border-color: #fecaca;
        background: #fff1f2;
        color: #dc2626;
      }

      .writer-stage {
        display: grid;
        grid-template-rows: 3.25rem 1fr;
        min-width: 0;
        min-height: 0;
        overflow: hidden;
        background: #f1f2f4;
      }

      .writer-toolbar {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 0.55rem;
        border-bottom: 1px solid var(--line);
        background: #f8f9fb;
        padding: 0 0.8rem;
        color: var(--muted);
        overflow: hidden;
      }
      .writer-tool-group {
        display: flex;
        align-items: center;
        gap: 0.16rem;
        min-width: 0;
        overflow-x: auto;
        overflow-y: hidden;
        scrollbar-width: none;
      }
      .writer-tool-group::-webkit-scrollbar { display: none; }
      .writer-action-tools {
        min-width: 0;
        max-width: min(35rem, 45vw);
        border-left: 1px solid #d9dde5;
        padding-left: 0.55rem;
      }

      .writer-tool {
        flex: 0 0 auto;
        border: 0;
        border-radius: 0.42rem;
        background: transparent;
        color: #374151;
        min-width: 1.72rem;
        height: 2rem;
        padding: 0 0.34rem;
        font-size: 1rem;
        font-weight: 800;
        line-height: 1;
      }
      .writer-tool:hover { background: #e9edf3; color: var(--text); }
      .writer-tool.is-text { font-size: 0.78rem; min-width: auto; padding: 0 0.58rem; }
      .writer-tool.active { background: #eaf3ff; color: var(--primary); }
      .writer-heading-select {
        flex: 0 0 auto;
        height: 2rem;
        border: 0;
        border-radius: 0.42rem;
        background: transparent;
        color: #374151;
        padding: 0 0.25rem;
        font-weight: 800;
        outline: none;
      }
      .writer-heading-select:hover { background: #e9edf3; }
      .writer-font-select {
        flex: 0 0 4.35rem;
        width: 4.35rem;
        height: 1.8rem;
        border: 1px solid #d9dde5;
        border-radius: 0.42rem;
        background: #fff;
        color: #374151;
        padding: 0 0.28rem;
        font-size: 0.78rem;
        font-weight: 700;
        outline: none;
      }
      .writer-font-select:hover { border-color: color-mix(in srgb, var(--primary) 30%, #d9dde5); }
      .writer-tool i {
        display: block;
        width: 1rem;
        height: 1rem;
        pointer-events: none;
      }
      .writer-divider {
        flex: 0 0 auto;
        width: 1px;
        height: 1.35rem;
        margin: 0 0.22rem;
        background: #d9dde5;
      }
      .writer-import { color: var(--primary); }

      .writer-paper-wrap {
        min-height: 0;
        overflow: auto;
        overscroll-behavior: contain;
        padding: 1.65rem 2rem 4rem;
      }
      body.preview-on .writer-paper-wrap {
        display: grid;
        grid-template-columns: minmax(18rem, var(--preview-split)) 10px minmax(18rem, 1fr);
        gap: 0;
        padding: 1rem;
      }
      body.preview-on.preview-left .writer-paper-wrap {
        grid-template-columns: minmax(18rem, calc(100% - var(--preview-split))) 10px minmax(18rem, var(--preview-split));
      }
      .writer-paper {
        max-width: 49.5rem;
        min-height: calc(100vh - 12rem);
        margin: 0 auto;
        border: 1px solid #ebeef3;
        background: var(--paper);
        box-shadow: 0 18px 48px rgb(15 23 42 / 0.04);
      }
      body.preview-on .writer-paper {
        width: 100%;
        max-width: none;
        min-width: 0;
        margin: 0;
        border-radius: 0.65rem 0 0 0.65rem;
      }
      body.preview-on.preview-left .writer-paper {
        border-radius: 0 0.65rem 0.65rem 0;
      }
      .writer-title {
        width: calc(100% - 4.5rem);
        margin: 2.4rem 2.25rem 0;
        border: 0;
        border-bottom: 1px solid var(--line);
        padding: 0 0 0.75rem;
        outline: none;
        color: var(--text);
        font-size: 1.42rem;
      }
      .writer-content {
        width: calc(100% - 4.5rem);
        min-height: 34rem;
        margin: 1.5rem 2.25rem 2rem;
        border: 0;
        outline: none;
        resize: vertical;
        color: #2b2f36;
        font-family: "Microsoft YaHei", "PingFang SC", serif;
        font-size: 1rem;
        line-height: 2.05;
      }
      .writer-preview {
        display: none;
        max-width: 49.5rem;
        min-height: calc(100vh - 12rem);
        margin: 0 auto;
        border: 1px solid #ebeef3;
        background: #fff;
        box-shadow: 0 18px 48px rgb(15 23 42 / 0.04);
        padding: 2.25rem;
        overflow: auto;
      }
      body.preview-on .writer-preview {
        display: block;
        width: 100%;
        max-width: none;
        min-width: 0;
        margin: 0;
        border-radius: 0 0.65rem 0.65rem 0;
      }
      .writer-resizer {
        display: none;
        position: relative;
        z-index: 3;
        cursor: col-resize;
        background: transparent;
      }
      .writer-resizer::before {
        content: "";
        position: absolute;
        inset: 0 4px;
        border-radius: 999px;
        background: #d5dbe6;
        transition: background 0.18s ease, box-shadow 0.18s ease;
      }
      .writer-resizer:hover::before,
      body.resizing-preview .writer-resizer::before {
        background: var(--primary);
        box-shadow: 0 0 0 3px rgb(22 119 255 / 0.14);
      }
      body.preview-on .writer-resizer { display: block; }
      body.preview-on.preview-left .writer-preview {
        order: 1;
        border-radius: 0.65rem 0 0 0.65rem;
      }
      body.preview-on.preview-left .writer-resizer { order: 2; }
      body.preview-on.preview-left .writer-paper { order: 3; }
      .writer-preview h1 { margin: 0 0 1rem; font-size: 1.85rem; font-weight: 900; }
      .writer-preview h2 { margin: 1.4rem 0 0.75rem; font-size: 1.45rem; font-weight: 900; }
      .writer-preview h3 { margin: 1.2rem 0 0.6rem; font-size: 1.22rem; font-weight: 900; }
      .writer-preview p,
      .writer-preview li { color: #374151; line-height: 2; }
      .writer-preview-body { color: #374151; line-height: 2; }
      .writer-preview blockquote {
        margin: 1rem 0;
        border-left: 4px solid var(--primary);
        background: #f8fafc;
        padding: 0.7rem 1rem;
        color: var(--muted);
      }
      .writer-preview pre {
        overflow: auto;
        border-radius: 0.8rem;
        background: #111827;
        color: #e5e7eb;
        padding: 1rem;
      }
      .writer-preview code {
        border-radius: 0.35rem;
        background: #eef2ff;
        padding: 0.12rem 0.35rem;
      }
      .writer-preview pre code { background: transparent; padding: 0; }
      .writer-preview table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
      .writer-preview th,
      .writer-preview td { border: 1px solid var(--line); padding: 0.55rem 0.7rem; }
      .writer-preview img { max-width: 100%; border-radius: 0.8rem; margin: 1rem 0; }

      .writer-panel,
      .writer-card {
        display: grid;
        gap: 1rem;
      }
      .writer-card {
        gap: 0.75rem;
        border: 1px solid var(--line);
        border-radius: 0.8rem;
        background: #fff;
        padding: 1rem;
      }
      .writer-card h2 { margin: 0; font-size: 1rem; }
      .writer-field {
        display: grid;
        gap: 0.35rem;
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 800;
      }
      .writer-field input,
      .writer-field textarea,
      .writer-field select {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 0.55rem;
        background: #fff;
        color: var(--text);
        padding: 0.65rem 0.75rem;
        outline: none;
      }
      .writer-field textarea { min-height: 5rem; resize: vertical; }
      .writer-inline {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 0.45rem;
      }
      .writer-upload-btn {
        border: 1px solid var(--line);
        border-radius: 0.55rem;
        background: #f8fafc;
        color: var(--primary);
        padding: 0 0.7rem;
        font-weight: 900;
      }
      .writer-check {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        color: var(--text);
        font-size: 0.9rem;
        font-weight: 800;
      }
      .writer-help {
        margin: 0;
        color: var(--muted);
        font-size: 0.78rem;
        line-height: 1.7;
      }
      .writer-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-top: 1px solid var(--line);
        background: #fff;
        padding: 0 1.5rem;
        color: var(--muted);
        font-size: 0.82rem;
      }
      .hidden { display: none !important; }
      .writer-list,
      .writer-right,
      .writer-paper-wrap,
      .writer-preview,
      .writer-toolbar,
      .writer-tool-group {
        scrollbar-width: none;
        -ms-overflow-style: none;
      }
      .writer-list::-webkit-scrollbar,
      .writer-right::-webkit-scrollbar,
      .writer-paper-wrap::-webkit-scrollbar,
      .writer-preview::-webkit-scrollbar,
      .writer-toolbar::-webkit-scrollbar,
      .writer-tool-group::-webkit-scrollbar {
        width: 0;
        height: 0;
        display: none;
      }
      body.left-collapsed .writer-left { display: none; }
      body.right-collapsed .writer-right { display: none; }
      body.left-collapsed:not(.right-collapsed) .writer-main { grid-template-columns: minmax(0, 1fr) 18rem; }
      body.right-collapsed:not(.left-collapsed) .writer-main { grid-template-columns: 20rem minmax(0, 1fr); }
      body.left-collapsed.right-collapsed .writer-main { grid-template-columns: minmax(0, 1fr); }
      body.immersive .writer-topbar,
      body.immersive .writer-left,
      body.immersive .writer-right,
      body.immersive .writer-footer,
      body.immersive .writer-toolbar { display: none; }
      body.immersive .writer-shell { grid-template-rows: 1fr; }
      body.immersive .writer-main { grid-template-columns: minmax(0, 1fr); }
      body.immersive .writer-stage { grid-template-rows: 1fr; }
      body.immersive .writer-paper-wrap { padding: 1.25rem; }
      body.immersive .writer-paper,
      body.immersive .writer-preview { min-height: calc(100vh - 2.5rem); }

      @media (max-width: 1100px) {
        .writer-main { grid-template-columns: 17rem minmax(0, 1fr); }
        .writer-right { display: none; }
        .writer-toolbar { grid-template-columns: 1fr; height: auto; min-height: 3.25rem; padding: 0.45rem 0.65rem; }
        .writer-action-tools { border-left: 0; border-top: 1px solid #d9dde5; padding-left: 0; padding-top: 0.35rem; }
      }
      @media (max-width: 760px) {
        .writer-main { grid-template-columns: 1fr; }
        .writer-left { display: none; }
        .writer-topbar { align-items: flex-start; flex-direction: column; height: auto; padding: 0.85rem; }
        .writer-topbar > div:last-child { width: 100%; overflow-x: auto; scrollbar-width: none; }
        .writer-topbar > div:last-child::-webkit-scrollbar { display: none; }
        .writer-toolbar { position: sticky; top: 0; z-index: 12; }
        .writer-paper-wrap { padding: 0.75rem; }
        .writer-paper { width: 100%; min-height: calc(100vh - 12rem); padding: 1.5rem 1.25rem; }
        .writer-stage.is-previewing { grid-template-columns: minmax(18rem, 1fr) 0.45rem minmax(18rem, 1fr); overflow-x: auto; }
        .writer-right { width: min(100%, 22rem); }
      }
    </style>
    <style is:global>
      #article-list.writer-list {
        display: grid;
        gap: 0.8rem;
        min-height: 0;
        overflow: auto;
        overscroll-behavior: contain;
        padding: 1rem;
        align-content: start;
      }

      #article-list .writer-post {
        position: relative;
        display: grid;
        grid-template-rows: auto auto;
        gap: 0.72rem;
        min-height: 6.85rem;
        overflow: visible;
        border: 1px solid #dfe7f2;
        border-radius: 0.95rem;
        background: linear-gradient(135deg, rgb(255 255 255 / 0.98), rgb(246 250 255 / 0.96));
        padding: 0.88rem 0.88rem 0.78rem 1.05rem;
        color: inherit;
        text-align: left;
        text-decoration: none;
        box-shadow: 0 12px 30px rgb(15 23 42 / 0.045);
        transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
      }

      #article-list .writer-post[data-status="trash"] {
        border-color: #fed7d7;
        background: linear-gradient(135deg, #fffafa, #fff7f7);
      }

      #article-list .writer-post::before {
        content: "";
        position: absolute;
        inset: 0 auto 0 0;
        width: 0.24rem;
        background: #a7b2c4;
      }

      #article-list .writer-post[data-status="published"]::before { background: #16a34a; }
      #article-list .writer-post[data-status="draft"]::before { background: #f59e0b; }
      #article-list .writer-post[data-status="trash"]::before { background: #ef4444; }

      #article-list .writer-post:hover {
        border-color: color-mix(in srgb, var(--primary) 30%, #dbe4f0);
        box-shadow: 0 16px 36px rgb(15 23 42 / 0.08);
        transform: translateY(-1px);
      }

      #article-list .writer-post.active {
        border-color: color-mix(in srgb, var(--primary) 44%, white);
        background: linear-gradient(135deg, rgb(236 245 255 / 0.98), rgb(255 255 255 / 0.98));
        box-shadow: 0 14px 34px rgb(22 119 255 / 0.14);
      }

      #article-list .writer-post-main {
        display: grid;
        gap: 0.4rem;
        min-width: 0;
      }

      #article-list .writer-post-title {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: #172033;
        font-size: 0.98rem;
        font-weight: 900;
        line-height: 1.2;
      }

      #article-list .writer-post-meta {
