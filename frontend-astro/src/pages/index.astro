---
import BaseLayout from '@layouts/BaseLayout.astro'
import BaseCard from '@components/BaseCard.astro'
import { formatDate, getArticles } from '@/lib/api'

const { articles, pagination } = await getArticles({ page: 1, pageSize: 10 })
const featured = articles.find((post) => post.is_pinned || post.is_recommended) || articles[0]
const regularArticles = articles.filter((post) => post.id !== featured?.id)
const totalViews = articles.reduce((sum, post) => sum + Number(post.view_count || 0), 0)
const totalComments = articles.reduce((sum, post) => sum + Number(post.comment_count || 0), 0)
const categories = Array.from(
  new Map(
    articles
      .filter((post) => post.category_name)
      .map((post) => [post.category_slug || post.category_name, { name: post.category_name, slug: post.category_slug || post.category_name }])
  ).values()
)
const tags = Array.from(new Set(articles.flatMap((post) => post.tags?.map((tag) => tag.name) || [])))
const covers = ['/image1.webp', '/image2.webp', '/image3.webp']
---

<BaseLayout
  title="个人博客"
  subtitle="记录技术、生活与灵感的个人空间"
  sidebarProps={{ totalPosts: pagination?.total || articles.length, totalViews, totalComments, categories, tags }}
>
  <section class="grid gap-4 md:grid-cols-4">
    {[
      { href: '/archive', icon: '▣', title: '归档', desc: '按时间回看' },
      { href: '/search', icon: '⌕', title: '搜索', desc: '快速定位文章' },
      { href: '/admin/write', icon: '✎', title: '写作', desc: '进入独立写作台' },
      { href: '#latest', icon: '✦', title: '最新', desc: '继续向下阅读' },
    ].map((item) => (
      <a href={item.href} class="quick-card ryu-card group p-4 transition hover:-translate-y-1">
        <div class="mb-3 grid h-11 w-11 place-items-center rounded-2xl bg-primary/10 text-xl text-primary shadow-neu-in">{item.icon}</div>
        <h3 class="font-black group-hover:text-primary">{item.title}</h3>
        <p class="text-sm text-base-content/50">{item.desc}</p>
      </a>
    ))}
  </section>

  {featured && (
    <BaseCard class="featured-post overflow-hidden p-0">
      <a href={`/article/${featured.slug}`} class="grid md:grid-cols-5">
        <div class="relative min-h-56 md:col-span-2">
          <img class="absolute inset-0 h-full w-full object-cover" src="/image1.webp" alt="" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/45 to-transparent"></div>
          <div class="absolute bottom-4 left-4 flex flex-wrap gap-2">
            {featured.is_pinned && <span class="badge badge-warning">置顶</span>}
            {featured.is_recommended && <span class="badge badge-secondary">推荐</span>}
          </div>
        </div>
        <div class="p-6 md:col-span-3 md:p-8">
          <div class="mb-3 flex flex-wrap gap-2">
            {featured.category_name && <span class="badge badge-primary badge-outline">{featured.category_name}</span>}
            {featured.tags?.slice(0, 3).map((tag) => <span class="badge badge-ghost">{tag.name}</span>)}
          </div>
          <h2 class="text-3xl font-black leading-tight hover:text-primary md:text-4xl">{featured.title}</h2>
          {featured.excerpt && <p class="mt-4 text-base-content/70">{featured.excerpt}</p>}
          <div class="mt-6 flex flex-wrap justify-between gap-3 text-sm text-base-content/50">
            <span>{formatDate(featured.published_at || featured.created_at)}</span>
            <span>{featured.view_count || 0} 阅读 · {featured.comment_count || 0} 评论</span>
          </div>
        </div>
      </a>
    </BaseCard>
  )}

  <section id="latest" class="flex flex-col gap-4">
    <div class="flex items-center justify-between">
      <h2 class="text-2xl font-black">最新文章</h2>
      <a class="btn btn-sm btn-ghost rounded-xl" href="/archive">全部归档</a>
    </div>

    {regularArticles.map((post, index) => (
      <BaseCard class="post-card overflow-hidden p-0">
        <a href={`/article/${post.slug}`} class="grid md:grid-cols-[220px_1fr]">
          <div class="relative min-h-44">
            <img class="absolute inset-0 h-full w-full object-cover transition duration-500 hover:scale-105" src={covers[index % covers.length]} alt="" />
          </div>
          <div class="p-5">
            <div class="mb-3 flex flex-wrap gap-2">
              {post.category_name && <span class="badge badge-primary badge-outline">{post.category_name}</span>}
              {post.tags?.slice(0, 3).map((tag) => <span class="badge badge-ghost">{tag.name}</span>)}
            </div>
            <h3 class="text-2xl font-black leading-tight hover:text-primary">{post.title}</h3>
            {post.excerpt && <p class="mt-3 line-clamp-2 text-base-content/70">{post.excerpt}</p>}
            <div class="mt-5 flex flex-wrap justify-between gap-3 text-sm text-base-content/50">
              <span>{formatDate(post.published_at || post.created_at)}</span>
              <span>{post.view_count || 0} 阅读 · {post.like_count || 0} 喜欢 · {post.comment_count || 0} 评论</span>
            </div>
          </div>
        </a>
      </BaseCard>
    ))}

    {articles.length === 0 && (
      <BaseCard>
        <p class="text-center text-base-content/50">还没有发布文章。</p>
      </BaseCard>
    )}
  </section>
</BaseLayout>
