---
import { resolveUploadUrl } from '../lib/media'

interface Props {
  title: string
  subtitle?: string
  images?: string[]
}

const { title, subtitle = '', images = [] } = Astro.props
const normalizedImages = images
  .flatMap((item) => String(item).split(/\r?\n|,/))
  .map((item) => item.trim())
  .filter(Boolean)
const bannerImages = (normalizedImages.length ? normalizedImages : ['/home.webp']).map(resolveUploadUrl)
const payload = JSON.stringify(bannerImages)
---

<section class="banner relative isolate flex min-h-[46vh] items-center justify-center overflow-hidden px-4 pb-10 pt-20 text-center md:min-h-[50vh]" data-banner-images={payload}>
  <div class="banner-slides absolute inset-0 z-0">
    {bannerImages.map((src, index) => (
      <img class:list={['banner-slide absolute inset-0 h-full w-full object-cover', index === 0 && 'is-active']} src={src} alt="" />
    ))}
  </div>
  <div class="absolute inset-0 z-10 bg-black/45"></div>
  <div class="banner-wave absolute inset-x-0 bottom-[-1px] z-20 h-24"></div>

  <div class="relative z-30 mx-auto w-full max-w-blog text-white">
    <div class="mx-auto max-w-4xl animate-fade-in-up">
      <p class="mb-4 inline-flex rounded-full bg-white/15 px-4 py-2 text-sm font-bold uppercase tracking-normal backdrop-blur-md">
        Personal Publishing
      </p>
      <h1 class="text-5xl font-black leading-none drop-shadow-lg md:text-7xl">{title}</h1>
      {subtitle && <p class="mx-auto mt-5 max-w-2xl text-lg text-white/90 drop-shadow">{subtitle}</p>}
    </div>
  </div>
</section>

<script>
  function initBannerCarousel() {
    document.querySelectorAll<HTMLElement>('[data-banner-images]').forEach((banner) => {
      if (banner.dataset.ready === 'true') return;
      banner.dataset.ready = 'true';
      const slides = Array.from(banner.querySelectorAll<HTMLElement>('.banner-slide'));
      if (slides.length <= 1) return;
      let index = 0;
      window.setInterval(() => {
        slides[index]?.classList.remove('is-active');
        index = (index + 1) % slides.length;
        slides[index]?.classList.add('is-active');
      }, 5200);
    });
  }

  document.addEventListener('DOMContentLoaded', initBannerCarousel);
  document.addEventListener('astro:page-load', initBannerCarousel);
</script>
