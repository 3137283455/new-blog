---
import BaseCard from './BaseCard.astro'
import MusicPlayer from './MusicPlayer.astro'
import type { MusicTrack } from '../lib/api'

interface CategoryItem {
  name?: string
  slug?: string
}

interface StatItem {
  label: string
  value: number | string
}

interface SidebarSectionItem {
  label: string
  href?: string
  value?: number | string
}

interface SidebarSection {
  title: string
  marker?: string
  tone?: 'primary' | 'secondary' | 'accent'
  items: SidebarSectionItem[]
}

interface Props {
  totalPosts?: number
  totalViews?: number
  totalComments?: number
  statItems?: StatItem[]
  sidebarSections?: SidebarSection[]
  categories?: Array<string | CategoryItem>
  tags?: string[]
  musicPlaylist?: MusicTrack[]
  profileName?: string
  profileAvatar?: string
  profileBio?: string
}

const {
  totalPosts = 0,
  totalViews = 0,
  totalComments = 0,
  statItems,
  sidebarSections,
  categories = [],
  musicPlaylist = [],
  profileName = '个人博客',
  profileAvatar = '/profile.png',
  profileBio = '记录技术、生活和长期主义的小站。',
} = Astro.props

const categoryList = categories.length ? categories : ['技术', '生活', '随笔']
const profileStats = statItems?.length
  ? statItems.slice(0, 3)
  : [
      { label: '文章', value: totalPosts },
      { label: '阅读', value: totalViews },
      { label: '评论', value: totalComments },
    ]
const contextualSections: SidebarSection[] = sidebarSections ?? [
  {
    title: '分类',
    marker: '#',
    tone: 'primary',
    items: categoryList.map((category) => {
      const name = typeof category === 'string' ? category : category.name || ''
      const slug = typeof category === 'string' ? category : category.slug || name
      return { label: name, href: `/archive?category=${encodeURIComponent(slug)}` }
    }),
  },
  {
    title: '标签',
    marker: '✦',
    tone: 'secondary',
    items: [],
  },
]

const toneClass = {
  primary: 'text-primary',
  secondary: 'text-secondary',
  accent: 'text-accent',
}
---

<div class="sticky top-20 flex flex-col gap-4">
  <BaseCard class="overflow-hidden p-0 text-center">
    <div class="h-20 bg-gradient-to-br from-primary/30 via-secondary/20 to-accent/30"></div>
    <div class="-mt-10 px-5 pb-5">
      <img class="mx-auto h-20 w-20 rounded-full border-4 border-base-100 object-cover shadow-neu-out" src={profileAvatar} alt="个人头像" />
      <h2 class="mt-3 text-xl font-black">{profileName}</h2>
      <p class="mt-2 text-sm text-base-content/60">{profileBio}</p>
      <div class="mt-4 grid grid-cols-3 gap-2 text-center">
        {profileStats.map((item) => (
          <div class="rounded-xl bg-base-100/60 p-2">
            <strong class="block text-lg">{item.value}</strong>
            <span class="text-xs text-base-content/50">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </BaseCard>

  {contextualSections.map((section) => (
    section.items.length > 0 && (
      <BaseCard>
        <h3 class="mb-3 flex items-center gap-2 font-black">
          <span class={toneClass[section.tone || 'primary']}>{section.marker || '#'}</span>
          {section.title}
        </h3>
        <div class="flex flex-wrap gap-2">
          {section.items.map((item) => (
            item.href ? (
              <a class="badge badge-primary badge-outline gap-1 p-3 transition hover:badge-primary" href={item.href}>
                <span>{item.label}</span>
                {item.value !== undefined && <small class="opacity-70">{item.value}</small>}
              </a>
            ) : (
              <span class="badge badge-ghost gap-1 p-3">
                <span>{item.label}</span>
                {item.value !== undefined && <small class="opacity-70">{item.value}</small>}
              </span>
            )
          ))}
        </div>
      </BaseCard>
    )
  ))}

  <BaseCard class="music-widget">
    <MusicPlayer tracks={musicPlaylist} />
  </BaseCard>
</div>
